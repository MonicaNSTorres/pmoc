generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ambiente {
  id       Int     @id @default(autoincrement())
  nome     String  @unique
  cnpj     String?
  bairro   String?
  cidade   String?
  endereco String?
  numero   String?
  telefone String?
  uf       String?
  cep      String?
  pmocs    PMOC[]  @relation("AmbientePMOC")
  tags     Tag[]   @relation("AmbienteTags")
}

model Tag {
  id           Int           @id @default(autoincrement())
  tag          String
  unidade      String
  local        String
  ambienteId   Int?
  nome         String
  equipamentos Equipamento[] @relation("TagEquipamentos")
  pmocs        PMOC[]        @relation("TagPMOC")
  ambiente     Ambiente?     @relation("AmbienteTags", fields: [ambienteId], references: [id])
}

model Equipamento {
  id          Int    @id @default(autoincrement())
  modelo      String
  numeroSerie String
  tagId       Int
  tag         Tag    @relation("TagEquipamentos", fields: [tagId], references: [id])
}

model Servico {
  id         Int         @id @default(autoincrement())
  nome       String      @unique
  checklists Checklist[]
  pmocs      PMOC[]      @relation("ServicoPMOC")
}

model PMOC {
  id                   Int         @id @default(autoincrement())
  nomeAmbiente         String
  endereco             String
  numero               String
  bairro               String
  cidade               String
  uf                   String
  telefone             String?
  nomeProprietario     String
  cgcProprietario      String?
  enderecoProprietario String?
  nomeResponsavel      String
  cgcResponsavel       String
  conselho             String
  art                  String
  ambienteId           Int?
  servicoId            Int?
  tagId                Int?
  criadoEm             DateTime    @default(now())
  contrato             String?
  checklist            Checklist[]
  ambiente             Ambiente?   @relation("AmbientePMOC", fields: [ambienteId], references: [id])
  servico              Servico?    @relation("ServicoPMOC", fields: [servicoId], references: [id])
  tag                  Tag?        @relation("TagPMOC", fields: [tagId], references: [id])
}

model Checklist {
  id            Int       @id @default(autoincrement())
  descricao     String
  periodicidade String
  dataExecucao  DateTime?
  executadoPor  String?
  aprovadoPor   String?
  pmocId        Int
  servicoId     Int?
  pmoc          PMOC      @relation(fields: [pmocId], references: [id])
  servico       Servico?  @relation(fields: [servicoId], references: [id])
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nome     String
  email    String   @unique
  senha    String
  admin    Boolean  @default(false)
  criadoEm DateTime @default(now())
}
